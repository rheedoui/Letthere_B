# OptiX Bot — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# ── Storage ────────────────────────────────────────────────────────────────
DATA_DIR=./data               # Directory for SQLite database

# ── Scraper ────────────────────────────────────────────────────────────────
SCRAPER_LOOKBACK_DAYS=3       # How many days back to fetch arXiv papers
SCRAPER_MAX_RESULTS=50        # Max results per arXiv query

# ── Scorer (Phase 2) ───────────────────────────────────────────────────────
SCORER_MIN_SCORE=0.4          # Papers below this score are stored but not queued

# ── Claude API (Phase 2) ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=            # sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── Telegram (Phase 2) ────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=           # From @BotFather
TELEGRAM_CHAT_ID=             # Your personal chat ID or group ID

# ── X / Twitter (Phase 2) ─────────────────────────────────────────────────
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# ── Poster (Phase 2) ──────────────────────────────────────────────────────
POSTER_MIN_INTERVAL_MIN=30    # Minimum minutes between posted threads

# ── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                # DEBUG / INFO / WARNING / ERROR
